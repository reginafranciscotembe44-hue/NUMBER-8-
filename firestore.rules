rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Global Safety Net
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Global Helpers
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function userId() { return request.auth.uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // -------------------------------------------------------------------------
    // Tournament Rules
    // -------------------------------------------------------------------------
    function isValidTournament(data) {
      return data.keys().hasAll(['name', 'type', 'status', 'createdAt', 'createdBy']) &&
             data.keys().size() <= 12 && 
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.type in ['single_elimination', 'double_elimination', 'round_robin', 'survival', 'total_war'] &&
             data.status in ['draft', 'active', 'finished'] &&
             data.createdAt == request.time &&
             data.createdBy == userId();
    }

    match /tournaments/{tournamentId} {
      allow create: if isSignedIn() && isValidId(tournamentId) && isValidTournament(incoming());
      allow get: if isSignedIn() && resource.data.createdBy == userId();
      allow list: if isSignedIn() && resource.data.createdBy == userId();
      allow update: if isSignedIn() && existing().createdBy == userId() && (
        // Only owner can update. Immutable fields check:
        incoming().createdBy == existing().createdBy &&
        incoming().createdAt == existing().createdAt &&
        // Validate the rest of the shape (though partial updates might be tricky with isValidTournament)
        // For CQRS style actions, we'd be more specific. 
        // For simplicity here, we allow updating name, type, status, and settings.
        incoming().keys().hasAll(['name', 'type', 'status', 'createdAt', 'createdBy']) &&
        incoming().name is string && incoming().name.size() <= 100 &&
        incoming().status in ['draft', 'active', 'finished'] &&
        (!('winnerId' in incoming()) || incoming().winnerId is string)
      );
      allow delete: if isSignedIn() && existing().createdBy == userId();

      // -----------------------------------------------------------------------
      // Player Rules (Nested)
      // -----------------------------------------------------------------------
      function isValidPlayer(data) {
        return data.keys().hasAll(['name', 'tournamentId']) &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
               data.tournamentId == tournamentId;
      }

      match /players/{playerId} {
        allow create: if isSignedIn() && isValidId(playerId) && isValidPlayer(incoming()) && 
                        get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.createdBy == userId();
        allow read: if true;
        allow update, delete: if isSignedIn() && 
                                get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.createdBy == userId();
      }

      // -----------------------------------------------------------------------
      // Match Rules (Nested)
      // -----------------------------------------------------------------------
      function isValidMatch(data) {
        return data.keys().hasAll(['tournamentId', 'round', 'status']) &&
               data.tournamentId == tournamentId &&
               data.status in ['pending', 'in_progress', 'finished'];
      }

      match /matches/{matchId} {
        allow create: if isSignedIn() && isValidId(matchId) && isValidMatch(incoming()) &&
                        get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.createdBy == userId();
        allow read: if true;
        allow update: if isSignedIn() && 
                        get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.createdBy == userId() &&
                        isValidMatch(incoming());
        allow delete: if isSignedIn() && 
                        get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.createdBy == userId();
      }
    }
  }
}
