rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Global Safety Net
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Global Helpers
    // -------------------------------------------------------------------------
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // -------------------------------------------------------------------------
    // Tournament Rules
    // -------------------------------------------------------------------------
    function isValidTournament(data) {
      return data.keys().hasAll(['name', 'type', 'status', 'createdAt', 'createdBy']) &&
             data.keys().size() <= 12 && 
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.type in ['single_elimination', 'double_elimination', 'round_robin', 'survival', 'total_war'] &&
             data.status in ['draft', 'active', 'finished'] &&
             data.createdAt == request.time;
    }

    match /tournaments/{tournamentId} {
      allow create: if isValidId(tournamentId) && isValidTournament(incoming());
      allow read, update, delete: if true;

      // -----------------------------------------------------------------------
      // Player Rules (Nested)
      // -----------------------------------------------------------------------
      function isValidPlayer(data) {
        return data.keys().hasAll(['name', 'tournamentId']) &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
               data.tournamentId == tournamentId;
      }

      match /players/{playerId} {
        allow create: if isValidId(playerId) && isValidPlayer(incoming());
        allow read, update, delete: if true;
      }

      // -----------------------------------------------------------------------
      // Match Rules (Nested)
      // -----------------------------------------------------------------------
      function isValidMatch(data) {
        return data.keys().hasAll(['tournamentId', 'round', 'status']) &&
               data.tournamentId == tournamentId &&
               data.status in ['pending', 'in_progress', 'finished'];
      }

      match /matches/{matchId} {
        allow create: if isValidId(matchId) && isValidMatch(incoming());
        allow read, update, delete: if true;
      }
    }
  }
}
