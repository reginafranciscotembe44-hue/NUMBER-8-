rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Global Safety Net
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Global Helpers
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128; }
    
    // Check if user is the creator (Anyone with the ID is granted access in this simple model)
    function isAuthorized(tournamentId) {
      return isValidId(tournamentId);
    }

    // -------------------------------------------------------------------------
    // Tournament Rules
    // -------------------------------------------------------------------------
    function isValidTournament(data) {
      return data.keys().hasAll(['name', 'type', 'status', 'createdAt', 'createdBy', 'settings']) &&
             data.keys().size() <= 15 && 
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.type in ['single_elimination', 'double_elimination', 'round_robin', 'survival', 'total_war'] &&
             data.status in ['draft', 'active', 'finished'] &&
             data.createdBy is string && data.createdBy.size() > 0;
    }

    match /tournaments/{tournamentId} {
      allow create: if isValidId(tournamentId) && isValidTournament(incoming());
      allow read: if true; // Publicly viewable
      allow update, delete: if isValidId(tournamentId);

      // -----------------------------------------------------------------------
      // Player Rules (Nested)
      // -----------------------------------------------------------------------
      function isValidPlayer(data) {
        return data.keys().hasAll(['name', 'tournamentId']) &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
               data.tournamentId == tournamentId;
      }

      match /players/{playerId} {
        allow create: if isAuthorized(tournamentId) && isValidId(playerId) && isValidPlayer(incoming());
        allow read: if true;
        allow update, delete: if isAuthorized(tournamentId);
      }

      // -----------------------------------------------------------------------
      // Match Rules (Nested)
      // -----------------------------------------------------------------------
      function isValidMatch(data) {
        return data.keys().hasAll(['tournamentId', 'round', 'status']) &&
               data.tournamentId == tournamentId &&
               data.status in ['pending', 'in_progress', 'finished'];
      }

      match /matches/{matchId} {
        allow create: if isAuthorized(tournamentId) && isValidId(matchId) && isValidMatch(incoming());
        allow read: if true;
        allow update, delete: if isAuthorized(tournamentId);
      }
    }
  }
}
