rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Global Safety Net (Deny everything by default)
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Global Helpers
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function userId() { return request.auth.uid; }
    function isVerified() { 
      // For the AI Studio preview, we allow all signed-in users to perform actions 
      // even if they haven't verified their email yet. 
      // In production, you should re-enable: return isSignedIn() && request.auth.token.email_verified == true;
      return isSignedIn(); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Auth-based role check
    function isOwner() {
      return get(/databases/$(database)/documents/users/$(userId())).data.role == 'owner';
    }

    // -------------------------------------------------------------------------
    // User Rules
    // -------------------------------------------------------------------------
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'role', 'createdAt']) &&
             data.keys().size() <= 10 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.role in ['player', 'owner'] &&
             data.createdAt == request.time;
    }

    match /users/{uId} {
      // Basic profile read
      allow get, list: if isSignedIn();
      
      // Allow initial profile creation without verification for a better UX
      allow create: if isSignedIn() && uId == userId() && isValidUser(incoming());
      allow update: if isVerified() && uId == userId() && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'age', 'playStyle', 'bio', 'locationName', 'locationAddress', 'updatedAt']) &&
                    incoming().get('role', existing().role) == existing().role;

      // Notifications (Private to user)
      function isValidNotification(data) {
        return data.keys().hasAll(['userId', 'title', 'message', 'type', 'read', 'createdAt']) &&
               data.keys().size() <= 10 &&
               data.userId == uId &&
               data.title is string && data.title.size() <= 100 &&
               data.message is string && data.message.size() <= 1000 &&
               data.type is string &&
               data.read is bool &&
               data.createdAt == request.time;
      }

      match /notifications/{notificationId} {
        allow list, get: if isSignedIn() && uId == userId();
        allow create: if isSignedIn() && (uId == userId() || isOwner()) && isValidNotification(incoming());
        allow update: if isSignedIn() && uId == userId() && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
        allow delete: if isSignedIn() && uId == userId();
      }
    }

    // -------------------------------------------------------------------------
    // Tournament Rules
    // -------------------------------------------------------------------------
    function isValidTournament(data) {
      return data.keys().hasAll(['name', 'type', 'status', 'createdAt', 'createdBy']) &&
             data.keys().size() <= 15 &&
             data.name is string && data.name.size() <= 100 &&
             data.type is string &&
             data.status in ['draft', 'active', 'finished'] &&
             data.createdAt == request.time &&
             data.createdBy == userId();
    }

    match /tournaments/{tournamentId} {
      allow create: if isVerified() && isOwner() && isValidTournament(incoming());
      
      // Allow reading tournaments
      allow list, get: if isSignedIn() && (
        existing().get('status', 'draft') != 'draft' || 
        existing().createdBy == userId()
      );

      allow update: if isVerified() && existing().createdBy == userId() && 
                    existing().get('status', 'active') != 'finished' &&
                    incoming().createdBy == existing().createdBy;

      allow delete: if isVerified() && existing().createdBy == userId();

      // players and matches
      match /players/{playerId} {
        allow read: if isSignedIn();
        allow create: if isVerified() && (playerId == userId() || get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.createdBy == userId());
        allow update, delete: if isVerified() && get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.createdBy == userId();
      }

      match /matches/{matchId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isVerified() && get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.createdBy == userId();
      }
    }

    // -------------------------------------------------------------------------
    // Friendly Matches
    // -------------------------------------------------------------------------
    match /friendlyMatches/{matchId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && (incoming().player1Id == userId() || incoming().player2Id == userId());
      allow update: if isVerified() && (userId() == existing().player1Id || userId() == existing().player2Id);
      allow delete: if isVerified() && existing().createdBy == userId();
    }
  }
}
